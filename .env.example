# ─────────────────────────────────────────────────────────────
# .env.example — 새 환경변수가 생기면 키 이름만 여기에 추가.
# 실제 값은 `.env` (gitignore) 또는 Vercel 대시보드 / Doppler 에 보관.
# 사용: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# 사이트 root URL (canonical / sitemap / og:url 등에 사용)
NEXT_PUBLIC_SITE_URL=https://example.com

# 앱 환경 (development | preview | production) — Vercel 자동 주입
NODE_ENV=development

# 서버리스 지속성 백엔드 (Upstash Redis)
# When both are set, the app uses the persistent Upstash Redis store,
# otherwise it falls back to the in-memory store.
# On Vercel the build target is automatic while local/Docker self-host uses the standalone output.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
