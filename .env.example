# ─────────────────────────────────────────────────────────────
# .env.example — 새 환경변수가 생기면 키 이름만 여기에 추가.
# 실제 값은 `.env` (gitignore) 또는 Vercel 대시보드 / Doppler 에 보관.
# 사용: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# 사이트 root URL (canonical / sitemap / og:url 등에 사용)
NEXT_PUBLIC_SITE_URL=https://example.com

# 앱 환경 (development | preview | production) — Vercel 자동 주입
NODE_ENV=development

# Upstash Redis (영속 저장소) — 서버 전용 시크릿, NEXT_PUBLIC_ 접두사 금지.
# 둘 다 있으면 UpstashStorage 사용, 하나라도 없으면 in-memory 로 폴백.
# Vercel: Project Settings -> Environment Variables 에 설정.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
